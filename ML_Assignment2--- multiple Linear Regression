#__________Drop Out Risk------------

x = df[['gender', 'study_hours_per_day','exam_pressure','academic_performance','stress_level',
        'anxiety_score', 'depression_score','sleep_hours', 'physical_activity', 'social_support', 'screen_time',
        'internet_usage', 'financial_stress', 'family_expectation', 'burnout_score', 'mental_health_index' ]]
y = df['dropout_risk']
x_train, x_test, y_train, y_test = train_test_split(x,y, test_size=0.3, random_state=36)

dr_prediction = linear_model.LinearRegression()
dr_prediction.fit(x_train, y_train)
score = dr_prediction.score(x_train, y_train)
print("Score is:", score)
test = dr_prediction.predict(x_test)
print(test)
m = dr_prediction.coef_
print("Coefficient is:", m)
c = dr_prediction.intercept_
print("Intercept is:", c)

y_pred_train = dr_prediction.predict(x_train)
print(y_pred_train)
y_pred_test = dr_prediction.predict(x_test)
print(y_pred_test)
mse = mean_squared_error(y_test, y_pred_test)
print("MSE is:", mse)
r2 = r2_score(y_test, y_pred_test)
print("R2 Score is:", r2)
plt.title('Dropout Risk Prediction', color='black', fontweight='bold')
plt.xlabel("Factors Affecting Student's Performance", color = 'red', fontweight= 'bold')
plt.ylabel('Predicted Dropout Risk', color='red', fontweight='bold')

plt.scatter(y_train, y_pred_train)
plt.plot([y_pred_train.min(),y_pred_train.max()], [y_pred_train.min(),y_pred_train.max()], color = 'red')
plt.legend()
plt.show()

